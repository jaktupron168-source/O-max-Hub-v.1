        LangBtn.Text = "ภาษา: ไทย"
        PlayerTabBtn.Text = "ผู้เล่น"
        TeleportTabBtn.Text = "วาร์ป"
        SettingsTabBtn.Text = "ตั้งค่า"
        FlyBtn.Text = "รันสคริปต์บิน"
        NoclipBtn.Text = NoclipEnabled and "เดินทะลุ: เปิด" or "เดินทะลุ: ปิด"
        SpeedBtn.Text = SpeedEnabled and "วิ่งเร็ว: เปิด" or "วิ่งเร็ว: ปิด"
        InfJumpBtn.Text = InfJumpEnabled and "กระโดดไม่จำกัด: เปิด" or "กระโดดไม่จำกัด: ปิด"
        FullbrightBtn.Text = FullbrightEnabled and "สว่าง: เปิด" or "สว่าง: ปิด"
        ShowFpsBtn.Text = ShowFpsEnabled and "แสดง FPS: เปิด" or "แสดง FPS: ปิด"
        if FpsBoosted then FpsBoostBtn.Text = "Boot FPS: เปิดแล้ว" else FpsBoostBtn.Text = "Boot FPS" end
        TpToPlayerBtn.Text = "วาร์ปไปหาคนอื่น"
        TpToSpawnBtn.Text = "วาร์ปไปจุดเกิด"
        GetKeyBtn.Text = "ลิ้งค์เอาคีย์"
    else
        LangBtn.Text = "Language: EN"
        PlayerTabBtn.Text = "Player"
        TeleportTabBtn.Text = "Teleport"
        SettingsTabBtn.Text = "Settings"
        FlyBtn.Text = "Run Fly Script"
        NoclipBtn.Text = NoclipEnabled and "Noclip: ON" or "Noclip: OFF"
        SpeedBtn.Text = SpeedEnabled and "Speed: ON" or "Speed: OFF"
        InfJumpBtn.Text = InfJumpEnabled and "Infinite Jump: ON" or "Infinite Jump: OFF"
        FullbrightBtn.Text = FullbrightEnabled and "Fullbright: ON" or "Fullbright: OFF"
        ShowFpsBtn.Text = ShowFpsEnabled and "Show FPS: ON" or "Show FPS: OFF"
        if FpsBoosted then FpsBoostBtn.Text = "Boot FPS: DONE" else FpsBoostBtn.Text = "Boot FPS" end
        TpToPlayerBtn.Text = "Teleport to Player"
        TpToSpawnBtn.Text = "Teleport to Spawn"
        GetKeyBtn.Text = "Get Key"
    end
end

